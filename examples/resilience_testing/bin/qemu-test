#!/usr/bin/env bash
# Run the QEMU fault-injection suite.
#
# Boots the built firmware in QEMU on the host and runs the `:qemu`-tagged tests,
# each of which injects a fault from the outside (QMP / image / process) and
# asserts the guest reacted as expected. Extra args are passed through to
# `mix test` (e.g. bin/qemu-test test/qemu/disk_latency_test.exs).
set -euo pipefail

cd "$(dirname "$0")/.."

# The harness itself runs on the host target; it orchestrates the guest from
# outside rather than running on the device.
unset MIX_TARGET

# shellcheck source=bin/nerves-env.sh
source bin/nerves-env.sh

# Locate the firmware built for qemu_aarch64.
if [ -z "${FW_PATH:-}" ]; then
  FW_PATH="$(ls -t _build/qemu_aarch64_*/nerves/images/*.fw 2>/dev/null | head -n1 || true)"
fi
export FW_PATH

if [ -z "${FW_PATH:-}" ] || [ ! -f "$FW_PATH" ]; then
  echo "qemu-test: no firmware found under _build/. Run bin/build first." >&2
  exit 1
fi

if [ -z "${NERVES_SDK_IMAGES:-}" ] || [ ! -f "${NERVES_SDK_IMAGES}/little_loader.elf" ]; then
  echo "qemu-test: NERVES_SDK_IMAGES/little_loader.elf not found." >&2
  echo "qemu-test: run bin/build, then re-run (it sets up bin/nerves-env.sh)." >&2
  exit 1
fi

echo "qemu-test: FW_PATH=$FW_PATH"
echo "qemu-test: NERVES_SDK_IMAGES=$NERVES_SDK_IMAGES"

mix deps.get
exec mix test --only qemu "$@"
