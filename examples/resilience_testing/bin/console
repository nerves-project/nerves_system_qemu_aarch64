#!/usr/bin/env bash
# Interactive poking session for the peer-mode firmware.
#
# This firmware boots as an Erlang :peer node (the serial is the RPC link, not an
# IEx console), so "console" here means: open an IEx with the test harness loaded
# so you can boot a VM and drive it over :peer RPC by hand.
set -euo pipefail

cd "$(dirname "$0")/.."

unset MIX_TARGET

# shellcheck source=bin/nerves-env.sh
source bin/nerves-env.sh

if [ -z "${FW_PATH:-}" ]; then
  FW_PATH="$(ls -t _build/qemu_aarch64_*/nerves/images/*.fw 2>/dev/null | head -n1 || true)"
fi
export FW_PATH

if [ -z "${FW_PATH:-}" ] || [ ! -f "$FW_PATH" ]; then
  echo "console: no firmware found. Run bin/build first." >&2
  exit 1
fi

cat <<'MSG'
console: starting IEx with the resilience test harness loaded.

  alias ResilienceTesting.{VM, Faults, Guest}
  vm = VM.boot()                              # boot a VM (peer RPC over serial)
  VM.cmd(vm, "uname -a")                       # {output, exit_status}
  VM.call(vm, ResilienceTesting, :hello, [])   # => :world  (RPC, real terms)
  Faults.disk_throttle(vm, bps_rd: 1_048_576)  # inject a fault via QMP
  VM.power_off(vm); vm = VM.boot_again(vm)      # pull the plug, reboot
  VM.destroy(vm)                               # tear down

MSG

exec env MIX_ENV=test iex -S mix run --no-start
