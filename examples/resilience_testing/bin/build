#!/usr/bin/env bash
# Build the resilience-testing firmware for the QEMU aarch64 system.
#
# The system is wired by path (see mix.exs), so the first build compiles it from
# source. On macOS the Nerves tooling automatically runs that build inside its
# Docker container; on Linux it builds natively. Either way the firmware (.fw)
# and the system images land on the host for the QEMU harness to use.
set -euo pipefail

cd "$(dirname "$0")/.."

export MIX_TARGET=qemu_aarch64

mix deps.get
mix firmware

echo
echo "build: firmware ready. Run the fault-injection suite with: bin/qemu-test"
